# Copy to .env (the installer does this for you) and fill in. .env is git-ignored.

# ── OPTIONAL: web search (Exa) ──────────────────────────────────────────────
# If set, persona agents use Exa for grounded web search when the brain is thin.
# Without it the agent falls back to built-in WebSearch/WebFetch tools.
# Get a free key at exa.ai, then install: pip install "maskpersona-ai[search]"
EXA_API_KEY=

# ── voice isolation: NO key needed ──────────────────────────────────────────
# The voice extra (speaker fingerprinting) needs no account or token. Just install:
# pip install "maskpersona-ai[voice]"
# openai-whisper downloads its weights on first use; the ONNX speaker model is pulled
# once from a public model release. Nothing to configure here.

# ── OPTIONAL: evaluation tracing ────────────────────────────────────────────
# If set, eval answers are traced to LangSmith (free tier). If unset, MaskPersona AI
# transparently falls back to local JSONL traces under work/<slug>/traces/ and the
# auditor loop works identically offline.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# ── OPTIONAL: only if you run the persona/auditor outside Claude Code ────────
# Inside Claude Code the agents run on your subscription; no API key needed.
ANTHROPIC_API_KEY=
